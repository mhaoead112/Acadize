# ==============================================
# EduVerse Environment Variables
# Copy this to .env and fill in your values
# ==============================================

# --- REQUIRED ---
DATABASE_URL=postgres://user:password@localhost:5432/eduverse
JWT_SECRET=your-jwt-secret-here-min-32-chars
SESSION_SECRET=your-session-secret-here

# --- REQUIRED FOR PRODUCTION ---
# CORS_ORIGINS: comma-separated frontend URLs (no spaces)
CORS_ORIGINS=https://your-frontend.vercel.app

# REDIS_URL: required for multi-process cache sharing (e.g. upstash)
# REDIS_URL=redis://default:password@your-redis-host:6379

# PUBLIC_UPLOAD_DIRS: comma-separated upload folders exposed via /uploads (default: avatars,chat)
# PUBLIC_UPLOAD_DIRS=avatars,chat
# COOKIE_SECRET: for signed cookies (falls back to JWT_SECRET)
# COOKIE_SECRET=your-cookie-secret

# --- CLIENT (Vite) ---
# Set these in your Vercel project settings:
# VITE_API_URL=https://your-backend.onrender.com
# VITE_WS_URL=wss://your-backend.onrender.com

# --- Paymob & redirects ---
# CLIENT_URL: frontend origin (used for post-payment redirects to /checkout-success, /checkout-failed)
# Set in Paymob dashboard: redirect/callback URL = https://YOUR_API_DOMAIN/api/webhooks/paymob/callback
# CLIENT_URL=https://your-frontend.vercel.app
# Paymob (required for subscriptions)
# PAYMOB_API_KEY=your-paymob-api-key
# PAYMOB_INTEGRATION_ID=123456
# PAYMOB_IFRAME_ID=943777
# PAYMOB_HMAC_SECRET=your-hmac-secret

# --- OPTIONAL ---
# AI Features
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_API_KEY=your-google-api-key
SEARCH_ENGINE_ID=your-search-engine-id

# Email (SendGrid or SMTP)
# SENDGRID_API_KEY=your-sendgrid-key
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email
# SMTP_PASS=your-password

# File Uploads (Cloudinary)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-key
# CLOUDINARY_API_SECRET=your-cloudinary-secret

# Push Notifications (VAPID)
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# Error Tracking (Sentry)
# SENTRY_DSN=https://your-sentry-dsn

# Node Environment
NODE_ENV=development
PORT=3001
