# API Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# For production, set these to your actual domain:
# VITE_API_URL=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com

# Multi-tenant: Required when deploying on a generic host (*.onrender.com, *.vercel.app, etc.)
# Set this to your organization's subdomain so all API requests are scoped correctly.
# VITE_TENANT_SUBDOMAIN=your-org-subdomain
