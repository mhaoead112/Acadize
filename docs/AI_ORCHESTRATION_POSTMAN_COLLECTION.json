{
  "info": {
    "name": "AI Orchestration Integration Tests",
    "description": "Complete test collection for AI Orchestration Layer",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Get JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Subdomain",
                "value": "school1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@school.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Checkpoint 1: Authenticated Requests",
      "item": [
        {
          "name": "Student Tutor - Primary Path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Subdomain",
                "value": "school1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"traceId\": \"trace-checkpoint1-001\",\n  \"task\": {\n    \"type\": \"student_tutor\",\n    \"question\": \"What is photosynthesis and why is it important?\",\n    \"lessonId\": \"lesson-bio-101\",\n    \"courseId\": \"course-science-101\",\n    \"persona\": \"alex\"\n  },\n  \"context\": {\n    \"lessonId\": \"lesson-bio-101\",\n    \"courseId\": \"course-science-101\",\n    \"language\": \"en\"\n  },\n  \"config\": {\n    \"enableFallback\": true,\n    \"timeout\": 30000,\n    \"debug\": false\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/ai/orchestrate",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "ai", "orchestrate"]
            }
          }
        }
      ]
    },
