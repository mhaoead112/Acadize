{
  "info": {
    "name": "Acadize LMS API",
    "description": "REST API for Acadize Learning Management System. Multi-tenant; use variable `tenant_subdomain` or header X-Tenant-Subdomain. JWT via Auth tab or variable `access_token`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "acadize-docs"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "tenant_subdomain", "value": "default" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "courseId", "value": "" },
    { "key": "orgId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "retakeId", "value": "" },
    { "key": "submissionId", "value": "" },
    { "key": "assignmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health & Tenant",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health",
            "description": "Health check. No auth."
          }
        },
        {
          "name": "Tenant Info",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/tenant/info",
            "description": "Current organization context."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@school.edu\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"John Doe\",\n  \"role\": \"student\"\n}"
            },
            "url": "{{base_url}}/api/auth/register",
            "description": "Register new user. Password min 8 chars."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.token) pm.collectionVariables.set('access_token', j.token);",
                  "  if (j.refreshToken) pm.collectionVariables.set('refresh_token', j.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@school.edu\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login",
            "description": "Returns accessToken and refreshToken. Saves to collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh",
            "description": "Exchange refresh token for new access token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/logout",
            "description": "Revoke refresh token."
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Scan QR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"hex-token-from-qr\",\n  \"sessionId\": \"session-uuid\",\n  \"gpsLat\": 40.7128,\n  \"gpsLng\": -74.006\n}"
            },
            "url": "{{base_url}}/api/attendance/scan",
            "description": "Student check-in via QR. Rate limited."
          }
        },
        {
          "name": "My Attendance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/attendance/my?courseId=&dateFrom=&dateTo=",
              "host": ["{{base_url}}"],
              "path": ["api", "attendance", "my"],
              "query": [
                { "key": "courseId", "value": "" },
                { "key": "dateFrom", "value": "" },
                { "key": "dateTo", "value": "" }
              ]
            },
            "description": "Student's attendance history."
          }
        },
        {
          "name": "Session Attendance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/attendance/session/{{sessionId}}",
            "description": "Teacher: full list; Student: own record. Set variable sessionId."
          }
        },
        {
          "name": "Manual Attendance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"\",\n  \"userId\": \"\",\n  \"status\": \"present\"\n}"
            },
            "url": "{{base_url}}/api/attendance/manual",
            "description": "Teacher/Admin. status: present|absent|late|excused."
          }
        }
      ]
    },
